# ──────────────────────────────────────────────────────────────────────────────
# Non-sensitive configuration — safe to commit / share
# ──────────────────────────────────────────────────────────────────────────────

# GitLab instance base URL
GITLAB_URL=https://gitlab.com

# Jira / Confluence base URL (same host for both)
JIRA_URL=https://your-org.atlassian.net

# Default Jira project code used when searching for tickets
JIRA_DEFAULT_PROJECT=TSSA

# ──────────────────────────────────────────────────────────────────────────────
# SECRETS — do NOT put tokens here.
#
# All secrets (GitLab personal access tokens, Jira API token, Jira email) are
# stored in  data/tokens.json  which is excluded from version control.
#
# On first startup the app will read the deprecated env vars below (if present)
# and automatically migrate them into data/tokens.json, after which you can
# remove them from this file.
# ──────────────────────────────────────────────────────────────────────────────

# DEPRECATED — migrate to data/tokens.json instead
# GITLAB_TOKEN=your_personal_access_token_here
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your_jira_api_token_here
